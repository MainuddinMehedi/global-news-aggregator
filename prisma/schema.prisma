generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Category {
  id       String    @id @default(uuid())
  name     String    @unique
  articles ProcessedArticle[] @relation("ProcessedArticleCategories")
}

model User {
  id        String      @id @default(uuid())
  email     String?     @unique
  topics    UserTopic[]
  createdAt DateTime    @default(now())
}

model UserTopic {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  topicName      String
  lastNotifiedAt DateTime?
  article        ProcessedArticle?  @relation(fields: [articleId], references: [id])
  articleId      String?

  @@unique([userId, topicName])
}

model RawArticle {
  id             String   @id @default(uuid())
  title          String
  contentSnippet String   @db.Text
  url            String   @unique
  source         String
  sourceCountry  String?
  publishedAt    DateTime
  fetchedAt      DateTime @default(now())
  contentHash    String?  @unique
  rawMetadata    Json?

  processedArticle ProcessedArticle?

  @@index([publishedAt])
  @@index([sourceCountry])
}

model ProcessedArticle {
  id                   String   @id @default(uuid())
  rawArticleId         String   @unique
  rawArticle           RawArticle @relation(fields: [rawArticleId], references: [id], onDelete: Cascade)
  categories           Category[] @relation("ProcessedArticleCategories")
  entities             String[]
  sentimentScore       Float?
  biasNote             String?
  biasCategory         String?   // "Western", "Eastern", "Non-Western", "Neutral"
  perspectiveCountries String[]
  model                String?
  processedAt          DateTime @default(now())

  matchedTopics UserTopic[]
}

model AiUsage {
  id            String   @id @default(uuid())
  date          String   // Format: YYYY-MM-DD for easy querying
  provider      String
  model         String
  tokensUsed    Int
  estimatedCost Float
  success       Boolean
  createdAt     DateTime @default(now())

  @@index([date])
}
